{
  "name": "mirage",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "assets:validate": "node scripts/validate-game-assets.mjs",
    "assets:import:polyhaven": "node scripts/import-polyhaven-model.mjs",
    "assets:import:quaternius:city": "node scripts/import-quaternius-city.mjs",
    "assets:import:quaternius:characters": "node scripts/import-quaternius-characters.mjs",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:e2e": "playwright test",
    "format:check": "prettier --check app/game tests scripts .github eslint.config.mjs vitest.config.ts playwright.config.ts package.json pnpm-workspace.yaml public/game-assets/manifest.json",
    "check": "pnpm format:check && pnpm assets:validate && pnpm lint && pnpm typecheck && pnpm test:run && pnpm build"
  },
  "dependencies": {
    "@react-three/drei": "10.7.7",
    "@react-three/fiber": "9.6.1",
    "@react-three/rapier": "2.2.0",
    "lucide-react": "1.24.0",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "three": "0.185.1"
  },
  "devDependencies": {
    "@gltf-transform/cli": "4.4.1",
    "@playwright/test": "1.55.0",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/three": "0.185.1",
    "eslint": "9.39.1",
    "eslint-config-next": "16.2.6",
    "prettier": "3.8.2",
    "typescript": "5.9.3",
    "vitest": "4.0.18"
  }
}
